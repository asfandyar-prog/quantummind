# QuantumMind backend — environment template.
# Copy to .env and fill in real values. .env is gitignored; this template is committed.

# ── LLM seam ──────────────────────────────────────────────────
# One client (ChatOpenAI) serves every provider; only the base URL, model,
# and key change. Dev uses Groq's OpenAI-compatible endpoint; prod uses
# self-hosted vLLM. See app/core/llm.py.
LLM_PROVIDER=groq                       # groq | openai | vllm
LLM_MODEL=llama-3.1-8b-instant
LLM_ROUTER_MODEL=llama-3.1-8b-instant   # cheap model pinned for routing

# Resilience (Phase 2) — sane defaults in config.py; override only if needed:
# LLM_TIMEOUT_SECONDS=30
# LLM_MAX_ATTEMPTS=4
# LLM_RETRY_BASE_DELAY=0.5
# LLM_RETRY_MAX_DELAY=8.0

# Groq (dev default): get a key at https://console.groq.com
GROQ_API_KEY=

# openai / vllm: key for the OpenAI-compatible endpoint. For vLLM, set
# LLM_BASE_URL to the served endpoint; the key may be any placeholder
# (the seam defaults it to "EMPTY").
# LLM_API_KEY=
# LLM_BASE_URL=http://gpu-node:8000/v1

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
FRONTEND_URL=http://localhost:5173
CHROMA_PATH=./data/chroma

# ── Teacher / admin ───────────────────────────────────────────
TEACHER_PASSWORD=quantum2026

# ── Database & cache (Phase 1) ────────────────────────────────
# Single connection string — only this changes for managed vs self-hosted.
# Uses psycopg 3 (postgresql+psycopg://), which serves both the async app and
# sync Alembic. Local Docker (docker-compose.dev.yml):
DATABASE_URL=postgresql+psycopg://quantummind:quantummind@localhost:5432/quantummind
# Hosted Postgres (e.g. Neon) — add ?sslmode=require. Placeholder only:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
REDIS_URL=redis://localhost:6379/0
# Hosted Redis (e.g. Upstash) requires TLS — use the rediss:// scheme. Placeholder only:
# REDIS_URL=rediss://default:TOKEN@HOST:6379
# Optional tuning (sane defaults in config.py):
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=5
# EXAM_STATE_TTL_SECONDS=86400

